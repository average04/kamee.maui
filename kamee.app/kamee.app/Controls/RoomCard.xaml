<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:kamee.app.Models"
    x:Class="kamee.app.Controls.RoomCard"
    x:Name="this">

    <Border BackgroundColor="{StaticResource CardBg}"
            StrokeShape="RoundRectangle 10"
            Stroke="Transparent"
            WidthRequest="110"
            Margin="0,0,10,0">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding TapCommand, Source={x:Reference this}}"
                                  CommandParameter="{Binding Room, Source={x:Reference this}}" />
        </Border.GestureRecognizers>

        <VerticalStackLayout Spacing="0">

            <!-- Thumbnail area -->
            <Grid HeightRequest="60">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2D0D5E" Offset="0" />
                        <GradientStop Color="#080514" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- LIVE badge -->
                <Border BackgroundColor="{StaticResource Coral}"
                        StrokeShape="RoundRectangle 3"
                        Stroke="Transparent"
                        HorizontalOptions="Start" VerticalOptions="Start"
                        Margin="5,5,0,0" Padding="4,1">
                    <Label Text="LIVE" TextColor="White" FontSize="7" FontAttributes="Bold" />
                </Border>

                <!-- Viewer count -->
                <Label Text="{Binding Room.ViewerCount, Source={x:Reference this}, StringFormat='{0} 👁'}"
                       TextColor="White" FontSize="8"
                       HorizontalOptions="End" VerticalOptions="Start"
                       Margin="0,5,5,0" />

                <!-- Play button -->
                <Ellipse HeightRequest="26" WidthRequest="26"
                         Fill="{StaticResource Mint}"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                <Label Text="▶" TextColor="{StaticResource BgPrimary}"
                       FontSize="9" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       Margin="2,0,0,0" />
            </Grid>

            <!-- Info area -->
            <VerticalStackLayout Padding="6,6,6,8" Spacing="2">
                <Label Text="{Binding Room.Name, Source={x:Reference this}}"
                       TextColor="White" FontSize="9" FontAttributes="Bold"
                       LineBreakMode="TailTruncation" MaxLines="1" />
                <Label Text="{Binding Room.HostUsername, Source={x:Reference this}}"
                       TextColor="{StaticResource TextMuted}" FontSize="8"
                       LineBreakMode="TailTruncation" MaxLines="1" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Border>

</ContentView>
