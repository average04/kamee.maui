<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:kamee.app.ViewModels"
    x:Class="kamee.app.Views.Mobile.CreateRoomPage"
    x:DataType="vm:CreateRoomViewModel"
    BackgroundColor="{StaticResource BgPrimary}">

    <ScrollView>
        <VerticalStackLayout Padding="24,48,24,40" Spacing="0">

            <!-- Title -->
            <Label Text="🐢 Create a Room"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   Margin="0,0,0,28" />

            <!-- Room Name -->
            <Label Text="Room Name" TextColor="{StaticResource TextSecondary}"
                   FontSize="12" Margin="4,0,0,6" />
            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,24">
                <Entry Text="{Binding RoomName}"
                       Placeholder="What are you watching?"
                       Style="{StaticResource KameeEntry}" />
            </Border>

            <!-- Platform picker -->
            <Label Text="Platform" TextColor="{StaticResource TextSecondary}"
                   FontSize="12" Margin="4,0,0,12" />

            <CollectionView ItemsSource="{Binding Platforms}"
                            HeightRequest="180" Margin="0,0,0,24">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3"
                                     HorizontalItemSpacing="8" VerticalItemSpacing="8" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border Padding="0,12" HorizontalOptions="Fill">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CreateRoomViewModel}}, Path=SelectPlatformCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding .}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="11"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap"
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Privacy toggle -->
            <Border Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,32">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Private room (invite only)"
                               TextColor="{StaticResource TextPrimary}" FontSize="14" />
                        <Label Text="Only people you invite can join"
                               TextColor="{StaticResource TextMuted}" FontSize="11" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsPrivate}"
                            OnColor="{StaticResource Mint}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Coral}" FontSize="12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Margin="0,0,0,12" />

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <!-- Cancel -->
                <Border Grid.Column="0" Style="{StaticResource GhostPillBorder}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CancelCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Cancel" TextColor="{StaticResource Lavender}"
                           FontSize="15" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <!-- Create -->
                <Border Grid.Column="1" Style="{StaticResource MintPillBorder}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="{StaticResource Mint}" Offset="0" />
                            <GradientStop Color="{StaticResource MintDark}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CreateCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Create Room 🚀" TextColor="{StaticResource BgPrimary}"
                           FontSize="14" FontAttributes="Bold"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
