<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <!-- Converters -->
    <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
    <toolkit:IsNullConverter x:Key="IsNullConverter" />
    <toolkit:BoolToObjectConverter x:Key="BoolToSignInLabelConverter"
                                   TrueObject="Create account"
                                   FalseObject="Sign in" />
    <toolkit:BoolToObjectConverter x:Key="BoolToToggleLinkConverter"
                                   TrueObject="Already have an account? "
                                   FalseObject="Don't have an account? " />
    <toolkit:BoolToObjectConverter x:Key="BoolToToggleActionConverter"
                                   TrueObject="Sign in"
                                   FalseObject="Create one" />

    <!-- Entry style -->
    <Style x:Key="KameeEntry" TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="12,0" />
    </Style>

    <!-- Card border style -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
        <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
    </Style>

    <!-- Input border style -->
    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
        <Setter Property="Stroke" Value="{StaticResource BorderColor}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Mint pill button border -->
    <Style x:Key="MintPillBorder" TargetType="Border">
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeShape" Value="RoundRectangle 26" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <!-- Ghost pill button border -->
    <Style x:Key="GhostPillBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{StaticResource Lavender}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape" Value="RoundRectangle 26" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <!-- Section header label -->
    <Style x:Key="SectionHeader" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

</ResourceDictionary>
